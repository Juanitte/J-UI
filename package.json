{
  "name": "@juanitte/inoui",
  "version": "1.1.0",
  "description": "A modern React UI component library",
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "typescript",
    "component-library"
  ],
  "author": "Juan Francisco Hermo López",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Juanitte/Ino-UI.git"
  },
  "homepage": "https://github.com/Juanitte/Ino-UI#readme",
  "bugs": {
    "url": "https://github.com/Juanitte/Ino-UI/issues"
  },
  "type": "module",
  "main": "./dist/ino-ui.cjs",
  "module": "./dist/ino-ui.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/inoui.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ino-ui.mjs",
      "require": "./dist/ino-ui.cjs"
    },
    "./styles.css": "./dist/inoui.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b && cross-env BUILD_LIB=true vite build",
    "prepublishOnly": "npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "dayjs": "^1.11.0"
  },
  "peerDependenciesMeta": {
    "dayjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
